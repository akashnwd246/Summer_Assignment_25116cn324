#include <stdio.h>
#include <string.h>
int main() {
    char str[100];
    int choice;

    printf("Enter string to perform operations: ");
    scanf("%s",&str);

    while (1) {
        printf("\n String Operations \n");
        printf("1. Display Length\n2. Reverse String\n3. Exit\n");
        printf("Enter choice: ");
        scanf("%d",&choice);

        if (choice == 1) {
            printf("Length: %lu\n", strlen(str));
        } else if (choice == 2) {
            printf("Reversed string: ");
            for (int i = strlen(str) - 1; i >= 0; i--) {
                printf("%c",str[i]);
            }
            printf("\n");
        } else if (choice == 3) {
            printf("Exiting system.\n");
            break;
        } else {
            printf("Invalid choice.\n");
        }
    }

    return 0;
}
