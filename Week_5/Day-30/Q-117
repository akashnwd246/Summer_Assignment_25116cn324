#include <stdio.h>
int main() {
    int roll[50];
    char names[50][50];
    int n, i;

    printf("Enter total number of students: ");
    scanf("%d",&n);

    for (i = 0; i < n; i++) {
        printf("Enter Roll Number and Name for Student %d: ", i + 1);
        scanf("%d%s",&roll[i],&names[i]);
    }

    printf("\nRegistered Records \n");
    for (i = 0; i < n; i++) {
        printf("Roll No: %d,Name: %s\n",roll[i],names[i]);
    }
  return 0;
}
