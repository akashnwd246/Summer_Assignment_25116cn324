#include <stdio.h>
struct Staff {
    char name[50];
    float basic;
    float allowance;
    float gross;
};

int main() {
    struct Staff emp[100];
    int n, i;

    printf("Enter number of staff: ");
    scanf("%d",&n);

    for (i = 0; i < n; i++) {
        printf("\nEnter name: ");
        scanf("%s",&emp[i].name);
        printf("Enter basic salary: ");
        scanf("%f",&emp[i].basic);
        printf("Enter allowance: ");
        scanf("%f",&emp[i].allowance);

        emp[i].gross = emp[i].basic + emp[i].allowance;
    }

    printf("\n Payroll Statements \n");
    for (i = 0; i < n; i++) {
        printf("Name: %s,Gross Salary: Rs. %.2f\n",emp[i].name,emp[i].gross);
    }

    return 0;
}
