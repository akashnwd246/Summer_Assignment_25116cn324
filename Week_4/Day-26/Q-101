#include <stdio.h>
#include <stdlib.h>
int main() {
    int secret = 45;
    int guess;

    printf("Guess the  number (1 to 100):\n");

    while (1) {
        printf("Enter your guess: ");
        scanf("%d",&guess);

        if (guess == secret) {
            printf("Correct! You win.\n");
            break;
        } else if (guess < secret) {
            printf("Too low! Try again.\n");
        } else {
            printf("Too high! Try again.\n");
        }
    }

 return 0;
}
