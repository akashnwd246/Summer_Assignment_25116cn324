#include <stdio.h>
int main() {
    char str[100];
    int count[256] = {0};
    int i = 0, j = 0;

    printf("Enter a string: ");
    scanf("%s",str);

    while (str[i] != '\0') {
        if (count[(unsigned char)str[i]] == 0) {
            count[(unsigned char)str[i]] = 1;
            str[j] = str[i];
            j++;
        }
        i++;
    }
    str[j] = '\0';

    printf("String after removing duplicates: %s\n",str);

 return 0;
}
