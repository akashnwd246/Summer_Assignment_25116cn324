#include <stdio.h>
struct Contact {
    char name[50];
    char phone[15];
    char email[50];
};

int main() {
    struct Contact c[50];
    int n, i;

    printf("Enter number of contacts to save: ");
    scanf("%d",&n);

    for (i = 0; i < n; i++) {
        printf("\nEnter details for contact %d:\n", i + 1);
        printf("Name: ");
        scanf("%s",&c[i].name);
        printf("Phone Number: ");
        scanf("%s",&c[i].phone);
        printf("Email: ");
        scanf("%s",&c[i].email);
    }

    printf("\n Saved Contact List \n");
    for (i = 0; i < n; i++) {
        printf("Name: %s | Phone: %s | Email: %s\n",c[i].name,c[i].phone,c[i].email);
    }
  return 0;
}
