#include <stdio.h>
int main() {
    char str[100];
    int count[256] = {0};
    int i = 0, found = 0;

    printf("Enter a string: ");
    scanf("%s",str);

    while (str[i] != '\0') {
        if (count[(unsigned char)str[i]] == 1) {
            printf("First repeating character is: %c\n",str[i]);
            found = 1;
            break;
        }
        count[(unsigned char)str[i]]++;
        i++;
    }

    if (found == 0) {
        printf("No repeating character found.\n");
    }
  return 0;
}
