#include <stdio.h>
int main() {
  int n, rem, rev=0, temp;
  printf("Enter a Number:");
  scanf("%d",&n);
  temp=n;
  while(n>0){
    rem = n%10;
    rev = rev * 10 + rem;
    n = n/10; }
  if (temp==rev) {
    printf("it is a palindrome no.\n");
   }
  else {
    printf("it is not a palindrome no.\n");
     }
   return 0;
  ]
  
