#include <stdio.h>
int main() {
    int n,i,j,prime,largestfactor = -1;

    printf("Enter a number: ");
    scanf("%d",&n);

    for(i=2;i<=n;i++) {
        if(n % i ==0) {
            
            prime = 1;
            for(j=2;j<=i/2;j++) {
                if(i % j == 0) {
                    prime = 0;
                    break;
                }
            }

            if(prime == 1) {
                largestfactor = i;
            }
        }
    }

    if(largestfactor!= -1) {
        printf("The largest prime factor is: %d\n",largestfactor);
    } else {
        printf("No prime factors found.\n");
    }

    return 0;
}
