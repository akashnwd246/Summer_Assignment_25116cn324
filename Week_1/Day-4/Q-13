#include <stdio.h>
int main() {
    int n, i;
    int t1 = 0, t2 = 1, Term;

    printf("Enter the number of terms: ");
    scanf("%d",&n);

    printf("Fibonacci Series: ");

    for (i = 1; i <= n; i++) {
        printf("%d ",t1);
        Term = t1 + t2;
        t1 = t2;
        t2 = Term;
    }
    return 0;
}
