#include <stdio.h>
#include <math.h>

int main() {
    int start, end, i, temp1, temp2, rem, count, sum;
    printf("Enter starting and ending limits: ");
    scanf("%d%d",&start,&end);

    printf("Armstrong numbers between %d and %d are: ",start,end);
 for (i = start; i<=end;i++) {
        temp1 = i;
        temp2 = i;
        count = 0;
        sum = 0;

        while (temp1!=0) {
            temp1 = temp1/10;
            count++;
        }
         while (temp2!=0) {
            rem = temp2 % 10;
            sum = sum + pow(rem,count);
            temp2 = temp2/10;
        }

        if (sum == i) {
            printf("%d",i);
        }
    }
    return 0;
}
