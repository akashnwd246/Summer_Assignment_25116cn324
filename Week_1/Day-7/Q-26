#include <stdio.h>

int fib(int n) {
    int result;

    if (n == 1) {
        result = 0;
    } else if (n == 2) {
        result = 1;
    } else {
        result = fib(n - 1) + fib(n - 2);
    }

    return result;
}
int main() {
    int n;
    printf("Enter position: ");
    scanf("%d",&n);

    if (n <= 0) {
        printf("Invalid\n");
    } else {
        printf("Term: %d\n",fib(n));
    }

    return 0;
}
