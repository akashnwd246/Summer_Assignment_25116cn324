#include <stdio.h>

int main () {
  int n;
  unsigned long long factorial=1;
  printf("Enter a number:");
  scanf("℅d",&n);
  if(n>=0) {
    for(int i = 1; i<=n;i++) {
      factorial = factorial*i;}
       printf("Factorial of ℅d=℅llu\n",n,factorial);
       }
  else {
    printf("factorial not exist ") ; }
   return 0;
  }
  
