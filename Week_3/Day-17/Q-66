#include <stdio.h>
int main() {
    int a[50], b[50];
    int n1, n2, i, j, duplicate;

    printf("Enter size of first array: ");
    scanf("%d",&n1);
    printf("Enter elements: ");
    for (i = 0; i < n1; i++) {
        scanf("%d",&a[i]);
    }

    printf("Enter size of second array: ");
    scanf("%d",&n2);
    printf("Enter elements: ");
    for (i = 0; i < n2; i++) {
        scanf("%d",&b[i]);
    }

    printf("Union of arrays: ");
    for (i = 0; i < n1; i++) {
        printf("%d ",a[i]);
    }

    for (i = 0; i < n2; i++) {
        duplicate = 0;
        for (j = 0; j < n1; j++) {
            if (b[i] == a[j]) {
                duplicate = 1;
                break;
            }
        }
        if (duplicate == 0) {
            printf("%d ",b[i]);
        }
    }
    printf("\n");
 return 0;
}
