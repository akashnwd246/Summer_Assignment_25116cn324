#include <stdio.h>
int main() {
    int arr[100];
    int n, i, j, count, maxCount = 0, maxElement;

    printf("Enter number of elements: ");
    scanf("%d",&n);

    printf("Enter elements: ");
    for (i = 0; i < n; i++) {
        scanf("%d",&arr[i]);
    }

    maxElement = arr[0];

    for (i = 0; i < n; i++) {
        count = 1;
        for (j = i + 1; j < n; j++) {
            if (arr[i] == arr[j]) {
                count++;
            }
        }
        if (count > maxCount) {
            maxCount = count;
            maxElement = arr[i];
        }
    }

    printf("Element with maximum frequency: %d\n",maxElement);
 return 0;
}
