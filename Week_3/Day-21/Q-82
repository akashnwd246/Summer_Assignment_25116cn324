#include <stdio.h>
int main() {
    char str[100], temp;
    int len = 0, start, end;

    printf("Enter a string: ");
    scanf("%s",str);

    while (str[len] != '\0') {
        len++;
    }

    start = 0;
    end = len - 1;

    while (start < end) {
        temp = str[start];
        str[start] = str[end];
        str[end] = temp;
        start++;
        end--;
    }

    printf("Reversed string: %s\n",str);
return 0;
}
