#include <stdio.h>
int main() {
    int arr[100];
    int n, i, key, low, high, mid, found = -1;

    printf("Enter number of elements : ");
    scanf("%d",&n);

    printf("Enter elements: ");
    for (i = 0; i < n; i++) {
        scanf("%d",&arr[i]);
    }

    printf("Enter element to search: ");
    scanf("%d",&key);

    low = 0;
    high = n - 1;

    while (low <= high) {
        mid = (low + high) / 2;

        if (arr[mid] == key) {
            found = mid;
            break;
        } else if (arr[mid] < key) {
            low = mid + 1;
        } else {
            high = mid - 1;
        }
    }

    if (found != -1) {
        printf("Element found : %d\n", found);
    } else {
        printf("Element not found\n");
    }
 return 0;
}
