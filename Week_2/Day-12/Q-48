#include <stdio.h>
int Perfect(int n) {
    int result = 0;
    int sum = 0;
    int i;

    for (i = 1; i < n; i++) {
        if (n % i == 0) {
            sum = sum + i;
        }
    }

    if (sum == n) {
        result = 1;
    }

    return result;
}

int main() {
    int num, ans;

    printf("Enter a number: ");
    scanf("%d",&num);

    ans = Perfect(num);

    if (ans == 1) {
        printf("%d is a perfect number.\n",num);
    } else {
        printf("%d is not a perfect number.\n",num);
    }
return 0;
}
