#include <stdio.h>

int checkPalindrome(int n) {
    int result = 0;
    int temp = n;
    int rev = 0;
    int rem;

    while (temp > 0) {
        rem = temp % 10;
        rev = rev * 10 + rem;
        temp = temp / 10;
    }

    if (rev == n) {
        result = 1;
    }

    return result;
}

int main() {
    int num, ans;

    printf("Enter a number: ");
    scanf("%d",&num);

    ans = checkPalindrome(num);

    if (ans == 1) {
        printf("%d is a palindrome.\n",num);
    } else {
        printf("%d is not a palindrome.\n",num);
    }
  return 0;
}
