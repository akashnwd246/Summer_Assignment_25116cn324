#include <stdio.h>
int checkArmstrong(int n) {
    int result = 0;
    int temp1 = n;
    int temp2 = n;
    int count = 0;
    int sum = 0;
    int rem, i, power;

    while (temp1 != 0) {
        temp1 = temp1 / 10;
        count++;
    }

    while (temp2 != 0) {
        rem = temp2 % 10;
        power = 1;
        for (i = 1; i <= count; i++) {
            power = power * rem;
        }
        sum = sum + power;
        temp2 = temp2 / 10;
    }

    if (sum == n) {
        result = 1;
    }

    return result;
}

int main() {
    int num, ans;

    printf("Enter a number: ");
    scanf("%d",&num);

    ans = checkArmstrong(num);

    if (ans == 1) {
        printf("%d is an Armstrong number.\n",num);
    } else {
        printf("%d is not an Armstrong number.\n",num);
    }
return 0;
}
