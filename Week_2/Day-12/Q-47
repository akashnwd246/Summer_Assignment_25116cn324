#include <stdio.h>
int Fibonacci(int n) {
    int result;
    int t1 = 0, t2 = 1, next = 0, i;

    if (n == 1) {
        result = t1;
    } else if (n == 2) {
        result = t2;
    } else {
        for (i = 3; i <= n; i++) {
            next = t1 + t2;
            t1 = t2;
            t2 = next;
        }
        result = t2;
    }

    return result;
}

