#include <stdio.h>
int findFactorial(int n) {
    int result = 1;
    int i;

    for (i = 1; i <= n; i++) {
        result = result * i;
    }

    return result;
}

int main() {
    int num,ans;

    printf("Enter a number: ");
    scanf("%d",&num);

    if (num < 0) {
        printf("Invalid number.\n");
    } else {
        ans = findFactorial(num);
        printf("Factorial: %d\n",ans);
    }

    return 0;
}
